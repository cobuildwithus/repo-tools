{
  "name": "@cobuild/repo-tools",
  "version": "0.1.0",
  "description": "Shared repository operations tools for Cobuild repos",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/repo-tools"
  },
  "bugs": {
    "url": "https://github.com/cobuildwithus/repo-tools/issues"
  },
  "homepage": "https://github.com/cobuildwithus/repo-tools#readme",
  "type": "module",
  "bin": {
    "cobuild-open-exec-plan": "bin/cobuild-open-exec-plan",
    "cobuild-close-exec-plan": "bin/cobuild-close-exec-plan",
    "cobuild-doc-gardening": "bin/cobuild-doc-gardening",
    "cobuild-check-agent-docs-drift": "bin/cobuild-check-agent-docs-drift",
    "cobuild-committer": "bin/cobuild-committer"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "node --check test/repo-tools.test.mjs && bash -n bin/cobuild-open-exec-plan bin/cobuild-close-exec-plan bin/cobuild-doc-gardening bin/cobuild-check-agent-docs-drift bin/cobuild-committer src/open-exec-plan.sh src/close-exec-plan.sh src/doc-gardening.sh src/check-agent-docs-drift.sh src/committer.sh scripts/committer scripts/release.sh scripts/update-changelog.sh",
    "test": "node --test",
    "test:coverage": "node --experimental-test-coverage --test",
    "release:check": "npm run typecheck && npm test && npm pack --dry-run",
    "release:dry-run": "scripts/release.sh patch --dry-run",
    "release:patch": "scripts/release.sh patch",
    "release:minor": "scripts/release.sh minor",
    "release:major": "scripts/release.sh major",
    "release:alpha": "scripts/release.sh preminor --preid alpha"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
